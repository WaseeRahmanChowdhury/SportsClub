            <Button fx:id="ticketSaleSummaryButton" layoutX="10.0" layoutY="250.0" mnemonicParsing="false" onAction="#ticketSaleSummary" prefHeight="40.0" prefWidth="398.0" text="Ticket Sale Summary" />
         </children>
      </VBox>
      <Label layoutX="43.0" layoutY="96.0" prefHeight="17.0" prefWidth="313.0" text="Please select an option from the navigation menu" />
   </children>
</AnchorPane>
