<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.ScheduleMatchController"
            prefHeight="320.0" prefWidth="420.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Schedule New Match">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="65.0" text="Match Date:" />
        <DatePicker fx:id="matchDateField" layoutX="150.0" layoutY="60.0" prefWidth="230.0" />

        <Label layoutX="20.0" layoutY="105.0" text="Opponent Club Name:" />
        <TextField fx:id="opponentClubNameField" layoutX="150.0" layoutY="100.0" prefWidth="230.0" />

        <Label layoutX="20.0" layoutY="145.0" text="Venue Name:" />
        <TextField fx:id="venueNameField" layoutX="150.0" layoutY="140.0" prefWidth="230.0" />

        <Label fx:id="statusLabel" layoutX="20.0" layoutY="190.0" prefWidth="380.0" wrapText="true" textFill="GREEN" />

        <Button layoutX="290.0" layoutY="260.0" prefWidth="110.0" prefHeight="30.0" text="Schedule" onAction="#scheduleMatch" />

    </children>
</AnchorPane>
