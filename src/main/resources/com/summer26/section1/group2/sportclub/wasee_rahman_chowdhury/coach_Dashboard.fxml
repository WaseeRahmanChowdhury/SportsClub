<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="720.0" prefWidth="1000.0"
            fx:controller="com.summer26.section1.group2.sportclub.wasee_rahman_chowdhury.coach_Dashboard">

    <VBox spacing="0.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          prefWidth="260.0" style="-fx-background-color: #f2f4f7; -fx-border-color: #d0d0d0; -fx-border-width: 0 1 0 0;">

        <Label text="Coach Dashboard" style="-fx-font-size: 22px; -fx-font-weight: bold;">
            <VBox.margin>
                <Insets top="20.0" left="20.0" right="20.0" bottom="20.0"/>
            </VBox.margin>
        </Label>

        <Button text="Manage Roster" onAction="#openManageRoster" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>
        <Button text="Create Lineup" onAction="#openCreateLineup" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>
        <Button text="Schedule Training Session" onAction="#openScheduleTrainingSession" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>
        <Button text="Player Reports" onAction="#openPlayerReports" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>
        <Button text="Submit Match Analysis" onAction="#openSubmitMatchAnalysis" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>
        <Button text="Request Equipment" onAction="#openRequestEquipment" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>
        <Button text="Fixture List" onAction="#openFixtureList" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>
        <Button text="Player Availability Manager" onAction="#openPlayerAvailabilityManager" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false"/>

        <Button text="Logout" onAction="#logout" maxWidth="Infinity" prefHeight="50.0" mnemonicParsing="false">
            <VBox.margin>
                <Insets top="200.0"/>
            </VBox.margin>
        </Button>

    </VBox>

    <AnchorPane fx:id="mainpane" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="260.0" AnchorPane.rightAnchor="0.0"
                style="-fx-background-color: white;"/>

</AnchorPane>
