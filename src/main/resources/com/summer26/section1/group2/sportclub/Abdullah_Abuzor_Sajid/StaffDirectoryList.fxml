<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.StaffDirectoryListController"
            prefHeight="560.0" prefWidth="620.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Staff Directory">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="55.0" text="Search (name or ID):" />
        <TextField fx:id="searchField" layoutX="170.0" layoutY="50.0" prefWidth="230.0" />
        <Button layoutX="410.0" layoutY="50.0" prefWidth="90.0" text="Search" onAction="#onSearch" />

        <!-- Table fills all remaining space between the search row and the edit panel pinned
             to the bottom, so it grows/shrinks whenever the window is resized. -->
        <TableView fx:id="staffTable"
                   AnchorPane.topAnchor="90.0" AnchorPane.leftAnchor="20.0"
                   AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="235.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="idColumn" text="Staff ID" prefWidth="90.0" />
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="160.0" />
                <TableColumn fx:id="roleColumn" text="Role" prefWidth="120.0" />
                <TableColumn fx:id="departmentColumn" text="Department" prefWidth="110.0" />
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="100.0" />
            </columns>
        </TableView>

        <!-- Edit panel: a fixed-height strip pinned to the bottom of the window regardless of
             how tall the window is, instead of floating in the middle on a large screen. -->
        <AnchorPane AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                    prefHeight="230.0">
            <children>
                <Label layoutX="20.0" layoutY="0.0" text="Edit Selected Staff Member">
                    <font>
                        <Font name="Arial Bold" size="13.0" />
                    </font>
                </Label>

                <Label layoutX="20.0" layoutY="30.0" text="Staff ID:" />
                <Label fx:id="selectedStaffIdLabel" layoutX="150.0" layoutY="30.0" prefWidth="200.0" />

                <Label layoutX="20.0" layoutY="60.0" text="Full Name:" />
                <TextField fx:id="editNameField" layoutX="150.0" layoutY="55.0" prefWidth="230.0" />

                <Label layoutX="20.0" layoutY="95.0" text="Role/Designation:" />
                <TextField fx:id="editRoleField" layoutX="150.0" layoutY="90.0" prefWidth="230.0" />

                <Label layoutX="20.0" layoutY="130.0" text="Department:" />
                <TextField fx:id="editDepartmentField" layoutX="150.0" layoutY="125.0" prefWidth="230.0" />

                <Label layoutX="20.0" layoutY="165.0" text="Phone Number:" />
                <TextField fx:id="editPhoneField" layoutX="150.0" layoutY="160.0" prefWidth="230.0" />

                <Button layoutX="410.0" layoutY="155.0" prefWidth="130.0" prefHeight="30.0" text="Save Changes" onAction="#saveChanges" />

                <Label fx:id="statusLabel" layoutX="20.0" layoutY="195.0" prefWidth="580.0" wrapText="true" textFill="GREEN" />
            </children>
        </AnchorPane>

    </children>
</AnchorPane>
