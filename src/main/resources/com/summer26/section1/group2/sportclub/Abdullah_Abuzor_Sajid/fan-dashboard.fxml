<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            prefHeight="720.0" prefWidth="1000.0"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.FanDashboardController">

    <top>
        <AnchorPane prefHeight="64.0" style="-fx-border-color: transparent transparent #cccccc transparent; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="Fan Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold;"
                       AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="20.0" />
                <Button fx:id="signoutButton" text="Sign Out" onAction="#signOut"
                        AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="16.0" />
            </children>
        </AnchorPane>
    </top>

    <left>
        <VBox spacing="8.0" prefWidth="230.0" style="-fx-border-color: transparent #cccccc transparent transparent; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="18.0" left="14.0" right="14.0" bottom="18.0" />
            </padding>
            <children>
                <Button fx:id="buyTicketButton" text="Buy Match Ticket" onAction="#buyTicket" maxWidth="Infinity" prefHeight="42.0" mnemonicParsing="false" />
                <Button fx:id="matchScheduleButton" text="Match Schedule" onAction="#matchSchedule" maxWidth="Infinity" prefHeight="42.0" mnemonicParsing="false" />
                <Button fx:id="ourPlayersButton" text="Our Players" onAction="#ourPlayers" maxWidth="Infinity" prefHeight="42.0" mnemonicParsing="false" />
                <Button fx:id="feedbackButton" text="Feedback and Complaints" onAction="#feedback" maxWidth="Infinity" prefHeight="42.0" mnemonicParsing="false" />
                <Button fx:id="leagueTableButton" text="League Table" onAction="#leagueTable" maxWidth="Infinity" prefHeight="42.0" mnemonicParsing="false" />
                <Button fx:id="clubShopButton" text="Club Shop" onAction="#clubShop" maxWidth="Infinity" prefHeight="42.0" mnemonicParsing="false" />
                <Button fx:id="matchResultsButton" text="Match Results" onAction="#matchResults" maxWidth="Infinity" prefHeight="42.0" mnemonicParsing="false" />
            </children>
        </VBox>
    </left>

    <center>
        <AnchorPane fx:id="contentArea">
            <children>
                <Label layoutX="24.0" layoutY="20.0" text="Please select an option from the navigation menu" style="-fx-text-fill: #666666;" />
            </children>
        </AnchorPane>
    </center>

</BorderPane>
