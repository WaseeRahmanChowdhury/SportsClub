<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.InitiateTransferController"
            prefHeight="400.0" prefWidth="420.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Initiate New Transfer">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="65.0" text="Player ID:" />
        <TextField fx:id="playerIdField" layoutX="170.0" layoutY="60.0" prefWidth="210.0" />

        <Label layoutX="20.0" layoutY="105.0" text="Direction:" />
        <ComboBox fx:id="directionCombo" layoutX="170.0" layoutY="100.0" prefWidth="210.0" promptText="Incoming/Outgoing" />

        <Label layoutX="20.0" layoutY="145.0" text="Counterpart Club:" />
        <TextField fx:id="counterpartClubField" layoutX="170.0" layoutY="140.0" prefWidth="210.0" />

        <Label layoutX="20.0" layoutY="185.0" text="Transfer Fee (BDT):" />
        <TextField fx:id="transferFeeField" layoutX="170.0" layoutY="180.0" prefWidth="210.0" />

        <Label layoutX="20.0" layoutY="225.0" text="Effective Date:" />
        <DatePicker fx:id="effectiveDateField" layoutX="170.0" layoutY="220.0" prefWidth="210.0" />

        <Label fx:id="statusLabel" layoutX="20.0" layoutY="270.0" prefWidth="380.0" wrapText="true" textFill="GREEN" />

        <Button layoutX="290.0" layoutY="340.0" prefWidth="110.0" prefHeight="30.0" text="Initiate" onAction="#initiateTransfer" />

    </children>
</AnchorPane>
