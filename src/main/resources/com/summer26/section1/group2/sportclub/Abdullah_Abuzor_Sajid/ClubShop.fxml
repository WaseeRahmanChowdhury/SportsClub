<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.ClubShopController"
            prefHeight="480.0" prefWidth="460.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Club Shop">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="60.0" text="Fan Membership ID:" />
        <TextField fx:id="fanMembershipIdField" layoutX="190.0" layoutY="55.0" prefWidth="230.0" promptText="e.g. FAN-0001" />

        <Label layoutX="20.0" layoutY="100.0" text="Item:" />
        <ComboBox fx:id="itemCombo" layoutX="190.0" layoutY="95.0" prefWidth="230.0" />

        <Label layoutX="20.0" layoutY="140.0" text="Quantity:" />
        <TextField fx:id="quantityField" layoutX="190.0" layoutY="135.0" prefWidth="230.0" />

        <Label layoutX="20.0" layoutY="180.0" text="Order Summary:" />
        <Label fx:id="summaryLabel" layoutX="190.0" layoutY="180.0" prefWidth="230.0" wrapText="true" />

        <Label layoutX="20.0" layoutY="235.0" text="Delivery Address:" />
        <TextField fx:id="deliveryAddressField" layoutX="20.0" layoutY="255.0" prefWidth="400.0" />

        <Label layoutX="20.0" layoutY="295.0" text="Payment Method:" />
        <ComboBox fx:id="paymentMethodCombo" layoutX="190.0" layoutY="290.0" prefWidth="230.0" />

        <Label fx:id="statusLabel" layoutX="20.0" layoutY="340.0" prefWidth="400.0" wrapText="true" textFill="GREEN" />

        <Button layoutX="290.0" layoutY="420.0" prefWidth="130.0" prefHeight="30.0" text="Place Order" onAction="#placeOrder" />

    </children>
</AnchorPane>
