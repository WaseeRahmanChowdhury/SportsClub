<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.summer26.section1.group2.sportclub.wasee_rahman_chowdhury.PlayerAvailabilityManagerController">

    <VBox spacing="15.0" AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="40.0"
          AnchorPane.rightAnchor="40.0" AnchorPane.bottomAnchor="30.0">

        <Label text="Player Availability Manager" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <TableView fx:id="playerTable" prefHeight="420.0" editable="true">
            <columns>
                <TableColumn fx:id="colName" text="Player Name" prefWidth="200.0"/>
                <TableColumn fx:id="colPosition" text="Position" prefWidth="100.0"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="140.0" editable="true"/>
                <TableColumn fx:id="colLastUpdated" text="Last Updated" prefWidth="140.0"/>
            </columns>
        </TableView>

        <Label fx:id="statusLabel" wrapText="true"/>

    </VBox>

</AnchorPane>
