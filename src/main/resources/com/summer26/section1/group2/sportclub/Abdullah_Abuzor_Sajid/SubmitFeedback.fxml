<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.FeedbackController"
            prefHeight="500.0" prefWidth="460.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Feedback and Complaints">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="60.0" text="Fan Membership ID:" />
        <TextField fx:id="fanMembershipIdField" layoutX="180.0" layoutY="55.0" prefWidth="240.0" promptText="e.g. FAN-0001" />

        <Label layoutX="20.0" layoutY="100.0" text="Feedback Type:" />
        <ComboBox fx:id="feedbackTypeCombo" layoutX="180.0" layoutY="95.0" prefWidth="240.0" />

        <Label layoutX="20.0" layoutY="140.0" text="Subject (max 100 chars):" />
        <TextField fx:id="subjectField" layoutX="20.0" layoutY="160.0" prefWidth="400.0" />

        <Label layoutX="20.0" layoutY="195.0" text="Description (max 1000 chars):" />
        <TextArea fx:id="descriptionArea" layoutX="20.0" layoutY="215.0" prefHeight="140.0" prefWidth="400.0" wrapText="true" />

        <Label layoutX="20.0" layoutY="365.0" text="Related Match (optional):" />
        <ComboBox fx:id="relatedMatchCombo" layoutX="20.0" layoutY="385.0" prefWidth="400.0" />

        <Label fx:id="statusLabel" layoutX="20.0" layoutY="425.0" prefWidth="400.0" wrapText="true" textFill="GREEN" />

        <Button layoutX="300.0" layoutY="460.0" prefWidth="120.0" prefHeight="30.0" text="Submit" onAction="#submitFeedback" />

    </children>
</AnchorPane>
