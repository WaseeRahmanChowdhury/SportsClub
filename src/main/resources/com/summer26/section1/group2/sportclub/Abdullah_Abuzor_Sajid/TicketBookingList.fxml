<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.TicketBookingListController"
            prefHeight="560.0" prefWidth="640.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Ticket Booking List">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="55.0" text="Search (booking ID or fan name):" />
        <TextField fx:id="searchField" layoutX="240.0" layoutY="50.0" prefWidth="220.0" />
        <Button layoutX="470.0" layoutY="50.0" prefWidth="90.0" text="Search" onAction="#onSearch" />

        <!-- Table fills all remaining space between the search row and the details panel pinned
             to the bottom, so it grows/shrinks whenever the window is resized. -->
        <TableView fx:id="bookingTable"
                   AnchorPane.topAnchor="90.0" AnchorPane.leftAnchor="20.0"
                   AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="225.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="bookingIdColumn" text="Booking ID" prefWidth="100.0" />
                <TableColumn fx:id="fanNameColumn" text="Fan Name" prefWidth="140.0" />
                <TableColumn fx:id="matchNameColumn" text="Match" prefWidth="170.0" />
                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="80.0" />
                <TableColumn fx:id="quantityColumn" text="Qty" prefWidth="45.0" />
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="65.0" />
            </columns>
        </TableView>

        <!-- Details panel: a fixed-height strip pinned to the bottom of the window regardless of
             how tall the window is, instead of floating in the middle on a large screen. -->
        <AnchorPane AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                    prefHeight="225.0">
            <children>
                <Label layoutX="20.0" layoutY="0.0" text="Booking Details">
                    <font>
                        <Font name="Arial Bold" size="13.0" />
                    </font>
                </Label>

                <Label layoutX="20.0" layoutY="30.0" text="Booking ID:" />
                <Label fx:id="detailBookingIdLabel" layoutX="160.0" layoutY="30.0" prefWidth="200.0" />

                <Label layoutX="20.0" layoutY="60.0" text="Fan Membership ID:" />
                <Label fx:id="detailFanMembershipIdLabel" layoutX="160.0" layoutY="60.0" prefWidth="200.0" />

                <Label layoutX="20.0" layoutY="90.0" text="Match:" />
                <Label fx:id="detailMatchLabel" layoutX="160.0" layoutY="90.0" prefWidth="400.0" />

                <Label layoutX="20.0" layoutY="120.0" text="Ticket Category:" />
                <Label fx:id="detailCategoryLabel" layoutX="160.0" layoutY="120.0" prefWidth="200.0" />

                <Label layoutX="20.0" layoutY="150.0" text="Quantity:" />
                <Label fx:id="detailQuantityLabel" layoutX="160.0" layoutY="150.0" prefWidth="200.0" />

                <Label layoutX="20.0" layoutY="180.0" text="Payment Status:" />
                <Label fx:id="detailStatusLabel" layoutX="160.0" layoutY="180.0" prefWidth="200.0" />
            </children>
        </AnchorPane>

    </children>
</AnchorPane>
