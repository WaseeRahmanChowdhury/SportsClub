<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.summer26.section1.group2.sportclub.wasee_rahman_chowdhury.SubmitMatchAnalysisController">

    <VBox spacing="20.0" AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0">

        <Label text="Submit Match Analysis" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <GridPane hgap="15.0" vgap="15.0">
            <Label text="Completed Match:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="completedMatchCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="280.0"/>

            <Label text="Overall Team Performance Rating (1-10):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="overallRatingField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="100.0"/>
        </GridPane>

        <Button text="Submit Analysis" onAction="#submitMatchAnalysis" mnemonicParsing="false"/>

        <Label fx:id="statusLabel" wrapText="true"/>

    </VBox>

</AnchorPane>
