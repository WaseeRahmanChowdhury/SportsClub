<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.PostAnnouncementController"
            prefHeight="440.0" prefWidth="440.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Post Announcement">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="65.0" text="Title:" />
        <TextField fx:id="titleField" layoutX="150.0" layoutY="60.0" prefWidth="250.0" />

        <Label layoutX="20.0" layoutY="105.0" text="Target Audience:" />
        <ComboBox fx:id="targetAudienceCombo" layoutX="150.0" layoutY="100.0" prefWidth="250.0" />

        <Label layoutX="20.0" layoutY="145.0" text="Priority:" />
        <ComboBox fx:id="priorityCombo" layoutX="150.0" layoutY="140.0" prefWidth="250.0" />

        <Label layoutX="20.0" layoutY="185.0" text="Content:" />
        <TextArea fx:id="contentArea" layoutX="20.0" layoutY="210.0" prefHeight="120.0" prefWidth="400.0" wrapText="true" />

        <Label fx:id="statusLabel" layoutX="20.0" layoutY="345.0" prefWidth="400.0" wrapText="true" textFill="GREEN" />

        <Button layoutX="310.0" layoutY="390.0" prefWidth="110.0" prefHeight="30.0" text="Publish" onAction="#postAnnouncement" />

    </children>
</AnchorPane>
