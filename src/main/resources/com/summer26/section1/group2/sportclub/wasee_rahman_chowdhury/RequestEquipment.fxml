<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.summer26.section1.group2.sportclub.wasee_rahman_chowdhury.RequestEquipmentController">

    <VBox spacing="20.0" AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0">

        <Label text="Request Equipment" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <GridPane hgap="15.0" vgap="15.0">
            <Label text="Item Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="itemNameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Quantity Needed:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="quantityNeededField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Intended Purpose:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextArea fx:id="intendedPurposeField" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="250.0" prefHeight="80.0" wrapText="true"/>

            <Label text="Urgency Level:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="urgencyLevelCombo" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="250.0"/>
        </GridPane>

        <Button text="Submit Request" onAction="#submitEquipmentRequest" mnemonicParsing="false"/>

        <Label fx:id="statusLabel" wrapText="true"/>

    </VBox>

</AnchorPane>
