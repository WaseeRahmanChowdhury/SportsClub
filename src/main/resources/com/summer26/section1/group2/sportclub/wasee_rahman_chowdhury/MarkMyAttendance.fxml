<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.wasee_rahman_chowdhury.MarkMyAttendanceController"
            prefHeight="530.0" prefWidth="490.0">
   <children>

      <Label layoutX="20.0" layoutY="15.0" text="Mark My Attendance">
         <font>
            <Font name="Arial Bold" size="18.0" />
         </font>
      </Label>

      <!-- event-3: today's training session, auto-fetched -->
      <Label layoutX="20.0" layoutY="65.0" text="Today's Session:" />
      <Label fx:id="sessionNameLabel" layoutX="160.0" layoutY="65.0" prefWidth="300.0" />

      <Label layoutX="20.0" layoutY="90.0" text="Session Time:" />
      <Label fx:id="sessionTimeLabel" layoutX="160.0" layoutY="90.0" prefWidth="300.0" />

      <Label layoutX="20.0" layoutY="115.0" text="Location:" />
      <Label fx:id="sessionLocationLabel" layoutX="160.0" layoutY="115.0" prefWidth="300.0" />

      <Label fx:id="statusLabel" layoutX="20.0" layoutY="165.0" prefWidth="450.0" wrapText="true" textFill="GREEN" />

      <!-- event-4: player clicks 'Mark My Attendance' button -->
      <Button layoutX="20.0" layoutY="480.0" prefWidth="200.0" prefHeight="32.0" text="Mark My Attendance" onAction="#markAttendance" />

   </children>
</AnchorPane>
