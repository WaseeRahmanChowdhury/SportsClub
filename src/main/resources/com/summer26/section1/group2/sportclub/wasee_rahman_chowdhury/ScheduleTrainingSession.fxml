<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.summer26.section1.group2.sportclub.wasee_rahman_chowdhury.ScheduleTrainingSessionController">

    <VBox spacing="20.0" AnchorPane.topAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0">

        <Label text="Schedule Training Session" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <GridPane hgap="15.0" vgap="15.0">
            <Label text="Date:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dateField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Start Time:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="startTimeField" promptText="e.g. 16:00" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="End Time:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="endTimeField" promptText="e.g. 18:00" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Venue:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="venueField" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Session Type:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <ComboBox fx:id="sessionTypeCombo" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Target Group:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <ComboBox fx:id="targetGroupCombo" GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="250.0"/>
        </GridPane>

        <Button text="Schedule Session" onAction="#scheduleTrainingSession" mnemonicParsing="false"/>

        <Label fx:id="statusLabel" wrapText="true"/>

    </VBox>

</AnchorPane>
