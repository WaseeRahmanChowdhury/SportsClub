<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.summer26.section1.group2.sportclub.Abdullah_Abuzor_Sajid.ClubActivityLogController"
            prefHeight="440.0" prefWidth="640.0">
    <children>

        <Label layoutX="20.0" layoutY="15.0" text="Club Activity Log">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>

        <Label layoutX="20.0" layoutY="55.0" text="Activity Type:" />
        <ComboBox fx:id="activityTypeCombo" layoutX="140.0" layoutY="50.0" prefWidth="180.0" onAction="#onFilterChanged" />

        <Label layoutX="340.0" layoutY="55.0" text="Search:" />
        <TextField fx:id="searchField" layoutX="400.0" layoutY="50.0" prefWidth="150.0" />
        <Button layoutX="560.0" layoutY="50.0" prefWidth="60.0" text="Go" onAction="#onSearch" />

        <TableView fx:id="activityTable"
                   AnchorPane.topAnchor="90.0" AnchorPane.leftAnchor="20.0"
                   AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="dateColumn" text="Activity Date" prefWidth="140.0" />
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="110.0" />
                <TableColumn fx:id="titleColumn" text="Activity Title" prefWidth="230.0" />
                <TableColumn fx:id="createdByColumn" text="Created By" prefWidth="110.0" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
