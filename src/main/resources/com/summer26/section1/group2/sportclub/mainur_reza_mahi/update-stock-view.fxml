<AnchorPane prefHeight="651.0" prefWidth="696.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer26.section1.group2.sportclub.mainur_reza_mahi.UpdateStockController">
   <children>
      <AnchorPane prefHeight="104.0" prefWidth="696.0">
         <children>
            <Label layoutX="35.0" layoutY="44.0" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Update Stock" />
            <Separator layoutX="35.0" layoutY="92.0" prefHeight="6.0" prefWidth="626.0" />
         </children>
      </AnchorPane>
      <AnchorPane layoutX="35.0" layoutY="100.0" prefHeight="200.0" prefWidth="200.0">
         <children>
            <Label layoutY="7.0" text="All Menu Items :">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            <TableView fx:id="allMenuItemTC" layoutY="39.0" prefHeight="200.0" prefWidth="626.0">
               <columns>
                  <TableColumn fx:id="itemIdTC" prefWidth="93.0" text="Item ID" />
                  <TableColumn fx:id="itemNameTC" prefWidth="163.0" style="-fx-background-color: #D4D4D4;" text="Item Name" />
                  <TableColumn fx:id="categoryTC" prefWidth="111.0" text="Category" />
                  <TableColumn fx:id="currentStockTC" prefWidth="124.0" style="-fx-background-color: #D4D4D4;" text="Current Stock" />
                  <TableColumn fx:id="stausTC" prefWidth="134.0" text="Status" />
