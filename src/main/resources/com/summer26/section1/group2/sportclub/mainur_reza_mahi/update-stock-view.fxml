               </columns>
            </TableView>
         </children>
      </AnchorPane>
      <VBox layoutX="35.0" layoutY="348.0" prefHeight="200.0" prefWidth="626.0">
         <children>
            <AnchorPane prefHeight="200.0" prefWidth="200.0">
               <children>
                  <Label layoutY="14.0" text="Update Stock Quantity :">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <TextField fx:id="itemIdTF" layoutX="128.0" layoutY="65.0" prefHeight="30.0" prefWidth="168.0" promptText="ORD-XXXX">
                     <cursor>
                        <Cursor fx:constant="TEXT" />
                     </cursor>
                  </TextField>
                  <TextField fx:id="quantityTF" layoutX="128.0" layoutY="107.0" prefHeight="30.0" prefWidth="168.0" promptText="e.g. 2">
                     <cursor>
                        <Cursor fx:constant="TEXT" />
                     </cursor>
                  </TextField>
                  <Text layoutX="26.0" layoutY="85.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Enter Item ID :">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Text>
                  <Text layoutX="19.0" layoutY="127.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Enter Quantity :">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Text>
                  <Button layoutX="223.0" layoutY="156.0" onAction="#updateStockButtonOA" prefHeight="30.0" prefWidth="180" style="-fx-background-color: #6495ED;" text="Update Stock" textFill="WHITE">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Button>
